{
  "name": "@six-socks-studio/cookie-consent",
  "version": "1.0.0",
  "description": "Self-hosted GDPR-compliant cookie consent solution for React and Next.js",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "gdpr",
    "cookie",
    "consent",
    "privacy",
    "cookie-banner",
    "cookie-consent",
    "nextjs",
    "react"
  ],
  "author": "Six Socks Studio <alessandro@sixsocks.studio>",
  "license": "MIT",
  "homepage": "https://github.com/six-socks-studio/cookie-consent#readme",
  "bugs": {
    "url": "https://github.com/six-socks-studio/cookie-consent/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/six-socks-studio/cookie-consent.git"
  },
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
